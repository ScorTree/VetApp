<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillAfter="true">

    <!-- Primer salto -->
    <translate
        android:fromYDelta="0dp"
        android:toYDelta="-15dp"
        android:duration="180"/>

    <translate
        android:fromYDelta="-15dp"
        android:toYDelta="0dp"
        android:startOffset="180"
        android:duration="180"/>

    <!-- Segundo salto -->
    <translate
        android:fromYDelta="0dp"
        android:toYDelta="-15dp"
        android:startOffset="420"
        android:duration="180"/>

    <translate
        android:fromYDelta="-15dp"
        android:toYDelta="0dp"
        android:startOffset="600"
        android:duration="180"/>

    <!-- Zoom suave -->
    <scale
        android:fromXScale="1.0"
        android:toXScale="1.08"
        android:fromYScale="1.0"
        android:toYScale="1.08"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="180"/>

    <scale
        android:fromXScale="1.08"
        android:toXScale="1.0"
        android:fromYScale="1.08"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:startOffset="180"
        android:duration="180"/>

</set>