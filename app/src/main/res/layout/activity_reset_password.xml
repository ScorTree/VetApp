<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:layout_marginTop="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva contraseña"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#8E7CC3"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etNuevaPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nueva contraseña"
            android:inputType="textPassword"
            android:drawableEnd="@android:drawable/ic_menu_view"
            android:textColor="@android:color/black"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#8E7CC3"
            android:padding="12dp"/>

        <LinearLayout
            android:id="@+id/layoutPasswordRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:background="#F7F4FF">

            <TextView
                android:id="@+id/tvPasswordStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fortaleza: Muy débil"
                android:textStyle="bold"
                android:textColor="#8E7CC3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPasswordBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="█░░░░░░░░░"
                android:textColor="#D32F2F"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvRuleLength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Mínimo 8 caracteres"
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvRuleUpper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Una letra mayúscula"
                android:textColor="#D32F2F"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRuleLower"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Una letra minúscula"
                android:textColor="#D32F2F"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRuleNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Un número"
                android:textColor="#D32F2F"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRuleSpecial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Un carácter especial"
                android:textColor="#D32F2F"
                android:textSize="13sp" />

        </LinearLayout>

        <EditText
            android:id="@+id/etConfirmarPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirmar contraseña"
            android:inputType="textPassword"
            android:drawableEnd="@android:drawable/ic_menu_view"
            android:textColor="@android:color/black"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#8E7CC3"
            android:padding="12dp"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnActualizarPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actualizar contraseña"
            android:backgroundTint="#8E7CC3"
            android:textColor="@android:color/white"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>