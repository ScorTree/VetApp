<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- Flecha regresar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/regresar"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#8E7CC3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/editar_mascota"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#8E7CC3"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card con formulario -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEditarMascota"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/nombre"
                android:inputType="textPersonName"
                android:autofillHints="name"
                android:textColor="#8E7CC3"/>

            <EditText
                android:id="@+id/etEspecie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/especie"
                android:inputType="text"
                android:autofillHints="none"
                android:textColor="#8E7CC3"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/etRaza"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/raza"
                android:inputType="text"
                android:autofillHints="none"
                android:textColor="#8E7CC3"
                android:layout_marginTop="12dp"/>

            <EditText
                android:id="@+id/etEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/edad"
                android:inputType="number"
                android:maxLength="2"
                android:autofillHints="none"
                android:textColor="#8E7CC3"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botón Guardar Cambios -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/guardar_cambios"
        android:textColor="@android:color/white"
        android:backgroundTint="#8E7CC3"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardEditarMascota"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
