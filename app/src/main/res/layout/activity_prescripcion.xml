<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnBackPresc"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_logout"
            app:tint="@color/morado"
            android:contentDescription="Regresar"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:text="Prescripción"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/morado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvPrescPaciente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/gray"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CONTADOR -->
    <TextView
        android:id="@+id/tvContadorPresc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 medicamento(s) en receta"
        android:textColor="@color/morado"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingStart="20dp"
        android:paddingBottom="8dp"/>

    <!-- TÍTULO DISPONIBLES -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medicamentos disponibles"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:paddingStart="20dp"
        android:paddingBottom="4dp"/>

    <!-- LISTA DISPONIBLES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMedicamentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:paddingTop="4dp"/>

    <!-- TÍTULO SELECCIONADOS -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="En la receta"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"/>

    <!-- LISTA SELECCIONADOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSeleccionados"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:paddingTop="4dp"/>

    <!-- BOTÓN GUARDAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarPresc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar prescripción"
        android:textAllCaps="false"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:backgroundTint="@color/morado"/>

</LinearLayout>