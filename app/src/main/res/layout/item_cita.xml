<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardCita"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- ICONO -->
        <ImageView
            android:id="@+id/ivMascota"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_pets"
            app:tint="@android:color/black"
            android:layout_marginEnd="12dp"
            android:layout_gravity="center_vertical"/>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Milton"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"/>

            <TextView
                android:id="@+id/tvInfoMascota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perro • Pitbull (5 años)"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="#E0E0E0"/>

            <TextView
                android:id="@+id/tvMotivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivo: Vacunación"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/morado"/>

            <TextView
                android:id="@+id/tvFechaHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha: 18/12/2025 a las 13:00"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvCosto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$350.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/morado"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvEstadoPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟠 Pendiente"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F57C00"
                android:layout_marginTop="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPagar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagar"
                android:textAllCaps="false"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/morado"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/tvEliminar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mantén presionado para eliminar"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
