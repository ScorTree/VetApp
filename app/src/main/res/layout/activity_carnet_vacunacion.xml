<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- Botón regresar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Regresar"
        app:tint="@color/morado"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Carnet de Vacunación"
        android:textColor="@color/morado"
        android:textStyle="bold"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card información mascota -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvNombreMascota"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Milton"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="@color/morado"/>

                    <TextView
                        android:id="@+id/tvInfoMascota"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Perro • Pitbull • 6 años"
                        android:textSize="16sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Resumen -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvCantidadVacunas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vacunas registradas: 0"
                        android:textStyle="bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:id="@+id/tvProximaVacuna"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Próxima vacuna: Sin información"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tvEstadoGeneral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="🟢 Todo al corriente"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="17sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Título listado -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Vacunas registradas"
                android:textStyle="bold"
                android:textColor="@color/morado"
                android:textSize="20sp"/>

            <!-- Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvVacunas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="8dp"/>

            <!-- Mensaje vacío -->
            <TextView
                android:id="@+id/tvSinVacunas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay vacunas registradas."
                android:textAlignment="center"
                android:textColor="#999999"
                android:padding="20dp"
                android:visibility="gone"/>

            <!-- Botón PDF (para implementar después) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDescargarPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="DESCARGAR CARNET PDF"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/morado"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>