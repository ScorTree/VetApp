<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- Flecha regresar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/regresar"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#8E7CC3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Nombre mascota -->
    <TextView
        android:id="@+id/tvNombreMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre Mascota"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#8E7CC3"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SCROLL GENERAL -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetalle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvNombreMascota"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD DATOS MASCOTA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvEspecie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/tvRaza"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/tvEdad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BOTÓN EDITAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/editar_mascota"
                android:backgroundTint="#8E7CC3"
                android:textColor="@android:color/white"/>

            <!-- BOTÓN ELIMINAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/eliminar_mascota"
                android:backgroundTint="#E57373"
                android:textColor="@android:color/white"/>

            <!-- HISTORIAL GENERAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/historial_general"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#8E7CC3"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:id="@+id/tvHistorialVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay historial registrado"
                android:textAlignment="center"
                android:textColor="#999999"
                android:visibility="gone"
                android:padding="8dp"/>


            <!-- MEDICINAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/medicinas"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#8E7CC3"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMedicinas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:id="@+id/tvMedicinasVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay medicinas registradas"
                android:textAlignment="center"
                android:textColor="#999999"
                android:visibility="gone"
                android:padding="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCarnetVacunacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="VER CARNET DE VACUNACIÓN"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/morado"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
