<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fitsSystemWindows="true">

    <!-- Flecha regresar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/regresar"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#8E7CC3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Califica nuestro servicio"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#8E7CC3"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <LinearLayout
                android:id="@+id/layoutStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="30dp">

                <ImageView
                    android:id="@+id/star1"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_star_empty"/>

                <ImageView
                    android:id="@+id/star2"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_star_empty"/>

                <ImageView
                    android:id="@+id/star3"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_star_empty"/>

                <ImageView
                    android:id="@+id/star4"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_star_empty"/>

                <ImageView
                    android:id="@+id/star5"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_star_empty"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona una calificación"
                android:layout_marginTop="16dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#444444"/>

            <EditText
                android:id="@+id/etComentario"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="24dp"
                android:hint="Escribe un comentario (opcional)"
                android:textColor="#000000"
                android:textColorHint="#808080"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:maxLines="5"
                android:gravity="top|start"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enviar Calificación"
                android:layout_marginTop="30dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>